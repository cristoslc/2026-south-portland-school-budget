---
interface Props {
  title: string;
  description?: string;
  activePage?: string;
}

const { title, description = 'Independent analysis of South Portland Schools\' FY27 budget proposal', activePage = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | SP Budget Watch</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <script is:inline>
    // Apply saved theme before first paint to prevent flash
    (function() {
      var saved = localStorage.getItem('theme');
      if (saved === 'dark' || saved === 'light') {
        document.documentElement.setAttribute('data-theme', saved);
      }
    })();
  </script>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href={base} class="site-title">SP Budget Watch</a>
      <nav class="site-nav">
        <a href={base} class:list={[{ active: activePage === 'home' }]}>Home</a>
        <a href={`${base}briefings/`} class:list={[{ active: activePage === 'briefings' }]}>Briefings</a>
        <a href={`${base}personas/`} class:list={[{ active: activePage === 'personas' }]}>Perspectives</a>
        <a href={`${base}evidence/`} class:list={[{ active: activePage === 'evidence' }]}>Evidence</a>
        <a href={`${base}timeline/`} class:list={[{ active: activePage === 'timeline' }]}>Timeline</a>
        <a href={`${base}about/`} class:list={[{ active: activePage === 'about' }]}>About</a>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle dark mode">
          <span class="icon" id="theme-icon"></span>
          <span id="theme-label"></span>
        </button>
      </nav>
    </div>
  </header>

  <div class="research-banner">
    Independent research project — not affiliated with the South Portland School Department or City of South Portland.
    AI-assisted analysis with full source transparency.
    <a href={`${base}about/`}>Learn more.</a>
  </div>

  <slot />

  <footer class="site-footer">
    <div class="footer-inner">
      <p>
        <strong>SP Budget Watch</strong> — Independent analysis of the South Portland Schools FY27 budget.
        Built with sourced evidence from public meetings and budget documents.
      </p>
      <p class="footer-disclaimer">
        This is an independent, volunteer project. It is not affiliated with or endorsed by the
        South Portland School Department or City of South Portland. All analysis is AI-assisted
        with full source transparency.
        <a href={`${base}about/`}>Learn more about our methodology.</a>
      </p>
    </div>
  </footer>
  <script is:inline>
    (function() {
      var btn = document.getElementById('theme-toggle');
      var icon = document.getElementById('theme-icon');
      var label = document.getElementById('theme-label');
      var root = document.documentElement;

      // Three states: system (no data-theme), light, dark
      function getEffective() {
        var saved = localStorage.getItem('theme');
        if (saved === 'dark' || saved === 'light') return saved;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }

      function getSaved() {
        return localStorage.getItem('theme'); // null means "system"
      }

      function update() {
        var saved = getSaved();
        var effective = getEffective();
        if (saved) {
          icon.textContent = effective === 'dark' ? '\u263E' : '\u2600';
          label.textContent = effective === 'dark' ? 'Dark' : 'Light';
        } else {
          icon.textContent = effective === 'dark' ? '\u263E' : '\u2600';
          label.textContent = 'Auto';
        }
      }

      btn.addEventListener('click', function() {
        var saved = getSaved();
        var effective = getEffective();
        // Cycle: auto -> light -> dark -> auto
        var next;
        if (!saved) {
          next = 'light';
        } else if (saved === 'light') {
          next = 'dark';
        } else {
          next = null; // back to auto
        }
        if (next) {
          localStorage.setItem('theme', next);
          root.setAttribute('data-theme', next);
        } else {
          localStorage.removeItem('theme');
          root.removeAttribute('data-theme');
        }
        update();
      });

      // Listen for system changes when in auto mode
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() {
        if (!getSaved()) update();
      });

      update();
    })();
  </script>
  <script is:inline>
    // Scroll-reveal: animate elements with .reveal class when they enter viewport
    (function() {
      var els = document.querySelectorAll('.reveal');
      if (!els.length) return;
      if (!('IntersectionObserver' in window)) {
        // Fallback: just show everything
        els.forEach(function(el) { el.classList.add('visible'); });
        return;
      }
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
      els.forEach(function(el) { observer.observe(el); });
    })();
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
