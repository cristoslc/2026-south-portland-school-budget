---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import {
  getTransportCommunityLens,
  getTransportCommunityLensEntries,
} from '../../../lib/transport-content.js';

export async function getStaticPaths() {
  const transportBriefings = await getCollection('transportBriefings');
  return getTransportCommunityLensEntries(transportBriefings).map(({ entry }) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const base = import.meta.env.BASE_URL;
const lens = getTransportCommunityLens(entry.id);
const lensSummary = lens?.summary ?? 'Transportation briefing.';
---

<BaseLayout
  title={entry.data.title}
  activePage="transportation-analysis"
  description={lensSummary}
  lastRefreshed={entry.data.generated_date}
>
  <main class="container">
    <a href={`${base}transportation-analysis/briefings/`} class="back-link">&larr; Transportation Briefings</a>
    <span class="badge badge-general">Community lens</span>
    <h1>{entry.data.title}</h1>
    <p>{lensSummary}</p>
    <div class="briefing-meta">
      {entry.data.generated_date && <span>Updated: {entry.data.generated_date}</span>}
    </div>
    <article class="briefing-content">
      <Content />
    </article>
  </main>
</BaseLayout>
