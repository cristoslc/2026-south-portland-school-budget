---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { TRANSPORT_COMMUNITY_LENSES } from '../lib/transport-content.js';

const briefings = await getCollection('briefings');
const personas = await getCollection('personas');
const personaTitles = {};
personas.forEach(p => { personaTitles[p.data.artifact] = p.data.title; });

const generalBriefings = briefings.filter(b => b.data.brief_type === 'general');
const personaBriefings = briefings.filter(b => b.data.persona_id).sort((a, b) => {
  const aId = parseInt((a.data.persona_id || '').replace('PERSONA-', '') || '0');
  const bId = parseInt((b.data.persona_id || '').replace('PERSONA-', '') || '0');
  return aId - bId;
});

const BUDGET_LENS_CATEGORIES = [
  { ids: ['PERSONA-001', 'PERSONA-002', 'PERSONA-003', 'PERSONA-008', 'PERSONA-011'], label: 'Parent', className: 'badge-parent' },
  { ids: ['PERSONA-004', 'PERSONA-015'], label: 'Educator', className: 'badge-teacher' },
  { ids: ['PERSONA-005', 'PERSONA-006', 'PERSONA-007'], label: 'Community', className: 'badge-community' },
  { ids: ['PERSONA-009', 'PERSONA-010'], label: 'Media', className: 'badge-media' },
  { ids: ['PERSONA-012', 'PERSONA-013', 'PERSONA-014'], label: 'Student', className: 'badge-student' },
];

const budgetLensPreview = BUDGET_LENS_CATEGORIES
  .map(cat => {
    const match = personaBriefings.find(b => cat.ids.includes(b.data.persona_id || ''));
    return match ? { briefing: match, label: cat.label, className: cat.className } : null;
  })
  .filter(Boolean);

const base = import.meta.env.BASE_URL;

const latestDate = briefings
  .map(b => b.data.generated_date)
  .filter(Boolean)
  .sort()
  .pop();
---

<BaseLayout title="Home" activePage="home" lastRefreshed={latestDate ? `Briefings ${latestDate}` : undefined}>
  <section class="hero">
    <div class="container">
      <h1>South Portland Budget Watch</h1>
      <p class="subtitle">
        Independent, AI-assisted analysis of the FY27 school budget proposal.
        Sourced from public meetings and budget documents. Written for residents, not accountants.
      </p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="number">$75.6M</span>
          <span class="label">Proposed Budget</span>
        </div>
        <div class="hero-stat">
          <span class="number">$8.4M</span>
          <span class="label">Structural Gap</span>
        </div>
        <div class="hero-stat">
          <span class="number">78</span>
          <span class="label">Positions Cut</span>
        </div>
        <div class="hero-stat">
          <span class="number">1</span>
          <span class="label">School Closure</span>
        </div>
      </div>
    </div>
  </section>

  <main class="container">
    <section class="reveal">
      <h2>What's Happening</h2>
      <p>
        South Portland Schools has proposed a $75.6 million budget for FY27 (2026-2027) — a 3.3% increase
        that still requires <strong>$8.4 million in cuts</strong> to bridge the gap between costs and revenue.
        The proposal includes eliminating 78 positions (12% of staff) and closing one elementary school.
      </p>
      <p>
        This site translates the raw budget into forms that residents can actually use. Every claim is
        sourced from public meetings and official documents. The analysis is AI-assisted with full
        transparency about methodology and limitations.
      </p>
    </section>

    <hr />

    <section class="reveal">
      <div class="section-header">
        <h2>Briefings & Analysis</h2>
        <a href={`${base}analysis/`}>View all &rarr;</a>
      </div>
      <p>Start here — general briefings and independent analysis tracks.</p>

      <div class="card-grid">
        {generalBriefings.map(briefing => (
          <a href={`${base}briefings/${briefing.id}/`} class="card">
            <span class="badge badge-general">General</span>
            <h3>{briefing.data.brief_mode === 'evergreen' ? 'General Budget Briefing' : 'Upcoming Meeting Briefing'}</h3>
            <p>
              {briefing.data.brief_mode === 'evergreen'
                ? 'Comprehensive overview of the FY27 budget proposal, cuts, and major decisions ahead.'
                : 'What to watch at the next budget meeting and what has changed since the last one.'}
            </p>
            <span class="briefing-meta">
              <span>Updated {briefing.data.generated_date}</span>
            </span>
          </a>
        ))}
        <a href={`${base}transportation-analysis/`} class="card">
          <span class="badge badge-community">Analysis</span>
          <h3>Transportation Analysis</h3>
          <p>Driver shortfalls, split-family counts, and fiscal exposure across the reconfiguration options.</p>
        </a>
        <a href={`${base}analysis/reconfiguration-context/`} class="card">
          <span class="badge badge-community">Analysis</span>
          <h3>Reconfiguration Context</h3>
          <p>The 2024 process — what the community said, what the Board directed, and what research says works.</p>
        </a>
      </div>
    </section>

    <hr />

    <section class="reveal">
      <div class="section-header">
        <h2>Budget Community Lenses</h2>
        <a href={`${base}briefings/`}>View all &rarr;</a>
      </div>
      <p>
        The same budget story told through the eyes of the people it affects — parents, educators,
        taxpayers, students, and the media covering the decisions.
      </p>

      <div class="card-grid">
        {budgetLensPreview.map(({ briefing, label, className }) => (
          <a href={`${base}briefings/${briefing.id}/`} class="card">
            <span class={`badge ${className}`}>{label}</span>
            <h3>{personaTitles[briefing.data.persona_id || ''] || briefing.data.persona_name}</h3>
            <p>{briefing.data.persona_name} — {briefing.data.upcoming_meeting_date || briefing.data.generated_date}</p>
          </a>
        ))}
      </div>
      <p style="margin-top: 1rem; text-align: center;">
        <a href={`${base}briefings/`}>See all {personaBriefings.length} budget community lenses &rarr;</a>
      </p>
    </section>

    <hr />

    <section class="reveal">
      <div class="section-header">
        <h2>Transportation Community Lenses</h2>
        <a href={`${base}transportation-analysis/briefings/`}>View all &rarr;</a>
      </div>
      <p>
        What the transportation decision means for daily routines, costs, and responsibilities —
        told through seven public lenses.
      </p>

      <div class="card-grid">
        {TRANSPORT_COMMUNITY_LENSES.slice(0, 6).map((lens) => {
          return (
            <a href={`${base}transportation-analysis/briefings/${lens.id}/`} class="card">
              <span class="badge badge-community">Community lens</span>
              <h3>{lens.label}</h3>
              <p>{lens.summary}</p>
            </a>
          );
        })}
      </div>
      <p style="margin-top: 1rem; text-align: center;">
        <a href={`${base}transportation-analysis/briefings/`}>See all {TRANSPORT_COMMUNITY_LENSES.length} transportation community lenses &rarr;</a>
      </p>
    </section>

    <hr />

    <section class="reveal">
      <h2>Key Dates</h2>
      <div class="timeline">
        <div class="timeline-item past">
          <div class="timeline-date">Mar 2</div>
          <div class="timeline-title">Budget Workshop I</div>
          <div class="timeline-desc">Nine elementary reconfiguration options presented with evaluation matrix.</div>
        </div>
        <div class="timeline-item past">
          <div class="timeline-date">Mar 16</div>
          <div class="timeline-title">Open Conversation with District Leadership</div>
          <div class="timeline-desc">Community Q&A session on the budget proposal.</div>
        </div>
        <div class="timeline-item past">
          <div class="timeline-date">Mar 23</div>
          <div class="timeline-title">Budget Workshop II</div>
          <div class="timeline-desc">Two elementary closure options presented. Personnel and non-personnel reductions detailed.</div>
        </div>
        <div class="timeline-item future">
          <div class="timeline-date">Mar 30</div>
          <div class="timeline-title">Budget Workshop III</div>
          <div class="timeline-desc">Continued board deliberation on the budget and elementary reconfiguration.</div>
        </div>
        <div class="timeline-item future">
          <div class="timeline-date">Apr 14</div>
          <div class="timeline-title">City Council Budget Workshop #1</div>
          <div class="timeline-desc">Council reviews the school budget allocation within the overall city spending plan.</div>
        </div>
        <div class="timeline-item future">
          <div class="timeline-date">Jun 9</div>
          <div class="timeline-title">Public Referendum Vote</div>
          <div class="timeline-desc">Maine law requires a public vote on the school budget.</div>
        </div>
      </div>
      <p style="margin-top: 1rem;">
        <a href={`${base}timeline/`}>Full timeline &rarr;</a>
      </p>
    </section>
  </main>
</BaseLayout>
