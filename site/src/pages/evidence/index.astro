---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { parse } from 'yaml';

const base = import.meta.env.BASE_URL;

// Load trove manifests for source counts and titles
function loadTrove(name: string) {
  try {
    const raw = readFileSync(resolve('..', 'docs', 'troves', name, 'manifest.yaml'), 'utf-8');
    const manifest = parse(raw);
    return {
      name: manifest.trove,
      refreshed: manifest.refreshed,
      sources: manifest.sources || [],
      count: (manifest.sources || []).length,
    };
  } catch {
    return { name, refreshed: '', sources: [], count: 0 };
  }
}

const budgetDocs = loadTrove('fy27-budget-documents');
const schoolBoard = loadTrove('school-board-budget-meetings');
const cityCouncil = loadTrove('city-council-meetings-2026');

const totalSources = budgetDocs.count + schoolBoard.count + cityCouncil.count;
const latestRefresh = [budgetDocs.refreshed, schoolBoard.refreshed, cityCouncil.refreshed]
  .filter(Boolean).sort().pop() || '';
---

<BaseLayout title="Sources" activePage="evidence" description="Primary sources behind the South Portland FY27 budget analysis." lastRefreshed={latestRefresh}>
  <main class="container">
    <h1>Sources</h1>
    <p>
      Every claim in our briefings traces back to specific public documents and meeting records.
      We currently track <strong>{totalSources} primary sources</strong> across three collections.
    </p>

    <section>
      <h2>Source Collections</h2>

      <div class="card-grid">
        <div class="card">
          <span class="badge badge-general">{budgetDocs.count} Documents</span>
          <h3>FY27 Budget Documents</h3>
          <p>
            Meeting packets, presentations, and spreadsheets from the district.
            Covers December 2025 through March 2026.
          </p>
          <ul class="source-list">
            {budgetDocs.sources.slice(0, 6).map((s: any) => (
              <li>{s.title}</li>
            ))}
            {budgetDocs.count > 6 && <li class="more">+ {budgetDocs.count - 6} more</li>}
          </ul>
          <div class="source-links">
            <a href="https://www.spsdme.org/budget27" target="_blank" rel="noopener">District budget page &rarr;</a>
          </div>
        </div>

        <div class="card">
          <span class="badge badge-general">{schoolBoard.count} Meetings</span>
          <h3>School Board Budget Meetings</h3>
          <p>
            Transcripts and analysis of board meetings where the budget was discussed.
            December 2025 through March 2026.
          </p>
          <ul class="source-list">
            {schoolBoard.sources.map((s: any) => (
              <li>{s.title}{s.duration ? ` (${s.duration})` : ''}</li>
            ))}
          </ul>
          <div class="source-links">
            <a href="https://vimeo.com/spctv" target="_blank" rel="noopener">SPC-TV Vimeo channel &rarr;</a>
            <a href="https://www.spsdme.org/school-board" target="_blank" rel="noopener">School Board page &rarr;</a>
          </div>
        </div>

        <div class="card">
          <span class="badge badge-general">{cityCouncil.count} Sources</span>
          <h3>City Council Meetings 2026</h3>
          <p>
            Council meeting transcripts and agendas covering budget-adjacent municipal context.
            January through March 2026.
          </p>
          <ul class="source-list">
            {cityCouncil.sources.filter((s: any) => s.type === 'media').map((s: any) => (
              <li>{s.title}{s.duration ? ` (${s.duration})` : ''}</li>
            ))}
          </ul>
          <div class="source-links">
            <a href="https://vimeo.com/spctv" target="_blank" rel="noopener">SPC-TV Vimeo channel &rarr;</a>
            <a href="https://southportland-gov.community.diligentoneplatform.com" target="_blank" rel="noopener">Meeting agendas (Diligent) &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <hr />

    <section>
      <h2>How Sources Become Briefings</h2>
      <div class="pipeline-flow">
        <div class="pipeline-step">
          <h4>1. Collection</h4>
          <p>Meeting transcripts, budget documents, and presentations are collected automatically from public sources twice daily.</p>
        </div>
        <div class="pipeline-step">
          <h4>2. Normalization</h4>
          <p>Raw files (VTT transcripts, PDFs, spreadsheets) are converted to structured markdown for consistent analysis.</p>
        </div>
        <div class="pipeline-step">
          <h4>3. Interpretation</h4>
          <p>Each meeting is analyzed through 15 stakeholder perspectives. The AI identifies what matters most to each persona and why.</p>
        </div>
        <div class="pipeline-step">
          <h4>4. Cumulative Narrative</h4>
          <p>New meeting interpretations are folded into running per-persona narratives — tracking how understanding evolves across meetings.</p>
        </div>
        <div class="pipeline-step">
          <h4>5. Briefings</h4>
          <p>Forward-looking briefings are generated from cumulative narratives, highlighting what changed, what to watch for, and open questions.</p>
        </div>
      </div>
    </section>

    <hr />

    <section>
      <h2>Original Source Portals</h2>
      <p>All source material comes from these public portals. You can verify any claim by checking the originals.</p>
      <table>
        <thead>
          <tr>
            <th>Portal</th>
            <th>What's There</th>
            <th>Link</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>SP School Department — Budget</td>
            <td>Budget presentations, packets, models, the budget book</td>
            <td><a href="https://www.spsdme.org/budget27" target="_blank" rel="noopener">spsdme.org/budget27</a></td>
          </tr>
          <tr>
            <td>SPC-TV Vimeo</td>
            <td>Full video recordings of school board and city council meetings</td>
            <td><a href="https://vimeo.com/spctv" target="_blank" rel="noopener">vimeo.com/spctv</a></td>
          </tr>
          <tr>
            <td>Diligent Community</td>
            <td>City council meeting agendas and minutes</td>
            <td><a href="https://southportland-gov.community.diligentoneplatform.com" target="_blank" rel="noopener">Diligent portal</a></td>
          </tr>
          <tr>
            <td>SP School Board</td>
            <td>Board meeting schedules, agendas, policies</td>
            <td><a href="https://www.spsdme.org/school-board" target="_blank" rel="noopener">spsdme.org/school-board</a></td>
          </tr>
        </tbody>
      </table>
    </section>

    <hr />

    <section>
      <h2>Key Budget Numbers</h2>
      <table>
        <thead>
          <tr>
            <th>Item</th>
            <th>Amount</th>
            <th>Context</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>FY26 Operating Budget</td>
            <td>$73.4M</td>
            <td>Current year baseline</td>
          </tr>
          <tr>
            <td>FY27 Roll-Forward Estimate</td>
            <td>$82.9M-$84.0M</td>
            <td>Same services + new contract rates + health insurance</td>
          </tr>
          <tr>
            <td>FY27 Proposed Budget</td>
            <td>$75.6M</td>
            <td>Superintendent's proposal (3.3% increase)</td>
          </tr>
          <tr>
            <td>Structural Gap</td>
            <td>$8.4M</td>
            <td>Required reductions to balance</td>
          </tr>
          <tr>
            <td>Positions Eliminated</td>
            <td>78 (12%)</td>
            <td>From 657 FTE to 579 FTE</td>
          </tr>
          <tr>
            <td>Special Education</td>
            <td>$16.4M</td>
            <td>Up from $12.7M two years ago</td>
          </tr>
          <tr>
            <td>Facilities Costs</td>
            <td>$7.3M</td>
            <td>Up from $6.2M two years ago</td>
          </tr>
          <tr>
            <td>Fund Balance (entering FY26)</td>
            <td>$739K</td>
            <td>Down from $5.9M in FY23</td>
          </tr>
        </tbody>
      </table>
    </section>

    <hr />

    <section>
      <h2>Staffing Impact</h2>
      <table>
        <thead>
          <tr>
            <th>Group</th>
            <th>FY26</th>
            <th>FY27</th>
            <th>Cut</th>
            <th>%</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Teachers (SPTA)</td>
            <td>354</td>
            <td>312</td>
            <td>42</td>
            <td>12%</td>
          </tr>
          <tr>
            <td>Ed Techs & Clerks (SPESPA)</td>
            <td>155</td>
            <td>139</td>
            <td>16</td>
            <td>10%</td>
          </tr>
          <tr>
            <td>Building Administrators (SPAA)</td>
            <td>13</td>
            <td>11</td>
            <td>2</td>
            <td>15%</td>
          </tr>
          <tr>
            <td>Facilities/Food/Transport (SEA)</td>
            <td>100</td>
            <td>86</td>
            <td>14</td>
            <td>14%</td>
          </tr>
          <tr>
            <td>Non-Bargaining</td>
            <td>35</td>
            <td>31</td>
            <td>4</td>
            <td>11%</td>
          </tr>
        </tbody>
      </table>
      <p style="font-size: 0.85rem; color: var(--color-slate);">
        Of the 78 reductions, approximately 20 can be absorbed through existing vacancies, retirements,
        or resignations, leaving about 58 positions where staff will be directly impacted.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .pipeline-flow {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .pipeline-step {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem;
    position: relative;
  }

  .pipeline-step h4 {
    color: var(--color-sky);
    margin: 0 0 0.5rem 0;
    font-size: 0.9rem;
  }

  .pipeline-step p {
    font-size: 0.85rem;
    color: var(--color-slate);
    margin: 0;
  }

  .source-list {
    font-size: 0.8rem;
    color: var(--color-slate);
    margin: 0.75rem 0;
    padding-left: 1.2rem;
  }

  .source-list li {
    margin-bottom: 0.25rem;
  }

  .source-list .more {
    list-style: none;
    margin-left: -1.2rem;
    font-style: italic;
    color: var(--color-sky);
  }

  .source-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
  }
</style>
