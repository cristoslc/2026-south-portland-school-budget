---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const personas = await getCollection('personas');
const sorted = personas.sort((a, b) => {
  const aNum = parseInt(a.data.artifact.replace('PERSONA-', ''));
  const bNum = parseInt(b.data.artifact.replace('PERSONA-', ''));
  return aNum - bNum;
});
const base = import.meta.env.BASE_URL;

const categoryMap: Record<string, { badge: string; className: string }> = {
  'PERSONA-001': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-002': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-003': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-004': { badge: 'Teacher', className: 'badge-teacher' },
  'PERSONA-005': { badge: 'Community', className: 'badge-community' },
  'PERSONA-006': { badge: 'Community', className: 'badge-community' },
  'PERSONA-007': { badge: 'Community', className: 'badge-community' },
  'PERSONA-008': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-009': { badge: 'Media', className: 'badge-media' },
  'PERSONA-010': { badge: 'Media', className: 'badge-media' },
  'PERSONA-011': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-012': { badge: 'Student', className: 'badge-student' },
  'PERSONA-013': { badge: 'Student', className: 'badge-student' },
  'PERSONA-014': { badge: 'Student', className: 'badge-student' },
  'PERSONA-015': { badge: 'Staff', className: 'badge-teacher' },
};

function getCategory(personaId: string): string {
  const parents = ['PERSONA-001', 'PERSONA-002', 'PERSONA-003', 'PERSONA-008', 'PERSONA-011'];
  const teachers = ['PERSONA-004', 'PERSONA-015'];
  const community = ['PERSONA-005', 'PERSONA-006', 'PERSONA-007'];
  const media = ['PERSONA-009', 'PERSONA-010'];
  const students = ['PERSONA-012', 'PERSONA-013', 'PERSONA-014'];
  if (parents.includes(personaId)) return 'parent';
  if (teachers.includes(personaId)) return 'teacher';
  if (community.includes(personaId)) return 'community';
  if (media.includes(personaId)) return 'media';
  if (students.includes(personaId)) return 'student';
  return 'other';
}

const groupMeta: Record<string, { label: string; className: string; description: string }> = {
  parent: { label: 'Parents', className: 'badge-parent', description: 'Parents of current and incoming students' },
  teacher: { label: 'Educators & Staff', className: 'badge-teacher', description: 'Teachers, specialists, and staff navigating staffing changes' },
  community: { label: 'Community', className: 'badge-community', description: 'Taxpayers, board members, and equity advocates' },
  media: { label: 'Media', className: 'badge-media', description: 'Journalists covering the budget story' },
  student: { label: 'Students', className: 'badge-student', description: 'Students directly affected by the budget' },
};

const grouped = Object.entries(groupMeta).map(([key, meta]) => ({
  ...meta,
  key,
  personas: sorted.filter(p => getCategory(p.data.artifact) === key),
})).filter(g => g.personas.length > 0);
---

<BaseLayout title="Perspectives" activePage="personas" description="15 community stakeholder perspectives on the South Portland FY27 school budget.">
  <main class="container">
    <h1>Community Perspectives</h1>
    <p>
      The budget affects different people in different ways. We've developed 15 stakeholder profiles
      representing the range of people affected — parents, teachers, staff, taxpayers, board members,
      journalists, community advocates, and students. Each perspective shapes how the budget analysis
      is presented.
    </p>

    {grouped.map(group => (
      <section>
        <h2>{group.label}</h2>
        <p>{group.description}</p>
        <div class="card-grid">
          {group.personas.map(persona => {
            const cat = categoryMap[persona.data.artifact] ?? { badge: 'Persona', className: 'badge-persona' };
            return (
              <a href={`${base}personas/${persona.data.artifact}/`} class="card">
                <span class={`badge ${cat.className}`}>{cat.badge}</span>
                <h3>{persona.data.title}</h3>
                <p>{persona.data.artifact}</p>
              </a>
            );
          })}
        </div>
      </section>
    ))}
  </main>
</BaseLayout>
