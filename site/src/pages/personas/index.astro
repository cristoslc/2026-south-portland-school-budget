---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const personas = await getCollection('personas');
const sorted = personas.sort((a, b) => {
  const aNum = parseInt(a.data.artifact.replace('PERSONA-', ''));
  const bNum = parseInt(b.data.artifact.replace('PERSONA-', ''));
  return aNum - bNum;
});
const base = import.meta.env.BASE_URL;

const categoryMap: Record<string, { badge: string; className: string }> = {
  'PERSONA-001': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-002': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-003': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-004': { badge: 'Teacher', className: 'badge-teacher' },
  'PERSONA-005': { badge: 'Community', className: 'badge-community' },
  'PERSONA-006': { badge: 'Community', className: 'badge-community' },
  'PERSONA-007': { badge: 'Community', className: 'badge-community' },
  'PERSONA-008': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-009': { badge: 'Media', className: 'badge-media' },
  'PERSONA-010': { badge: 'Media', className: 'badge-media' },
  'PERSONA-011': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-012': { badge: 'Student', className: 'badge-student' },
  'PERSONA-013': { badge: 'Student', className: 'badge-student' },
  'PERSONA-014': { badge: 'Student', className: 'badge-student' },
};
---

<BaseLayout title="Perspectives" activePage="personas" description="14 community stakeholder perspectives on the South Portland FY27 school budget.">
  <main class="container">
    <h1>Community Perspectives</h1>
    <p>
      The budget affects different people in different ways. We've developed 14 stakeholder profiles
      representing the range of people affected — parents, teachers, taxpayers, board members, journalists,
      community advocates, and students. Each perspective shapes how the budget analysis is presented.
    </p>

    <div class="card-grid">
      {sorted.map(persona => {
        const cat = categoryMap[persona.data.artifact] ?? { badge: 'Persona', className: 'badge-persona' };
        // Extract the display name from the title (format: "Concerned Elementary Parent")
        return (
          <a href={`${base}personas/${persona.data.artifact}/`} class="card">
            <span class={`badge ${cat.className}`}>{cat.badge}</span>
            <h3>{persona.data.title}</h3>
            <p>{persona.data.artifact}</p>
          </a>
        );
      })}
    </div>
  </main>
</BaseLayout>
