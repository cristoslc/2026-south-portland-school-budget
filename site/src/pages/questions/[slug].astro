---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

interface Evidence {
  trove: string;
  title: string;
  detail: string;
}

interface Question {
  slug: string;
  question: string;
  category: string;
  personas: string[];
  evidence: Evidence[];
  context: string;
}

let questions: Question[] = [];
try {
  const raw = readFileSync(resolve('..', 'dist', 'questions.json'), 'utf-8');
  questions = JSON.parse(raw);
} catch {
  // questions.json not yet generated
}

// Load persona names
const personaCollection = await getCollection('personas');
const personaNames: Record<string, string> = {};
const personaCategoryMap: Record<string, { badge: string; className: string }> = {
  'PERSONA-001': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-002': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-003': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-004': { badge: 'Teacher', className: 'badge-teacher' },
  'PERSONA-005': { badge: 'Community', className: 'badge-community' },
  'PERSONA-006': { badge: 'Community', className: 'badge-community' },
  'PERSONA-007': { badge: 'Community', className: 'badge-community' },
  'PERSONA-008': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-009': { badge: 'Media', className: 'badge-media' },
  'PERSONA-010': { badge: 'Media', className: 'badge-media' },
  'PERSONA-011': { badge: 'Parent', className: 'badge-parent' },
  'PERSONA-012': { badge: 'Student', className: 'badge-student' },
  'PERSONA-013': { badge: 'Student', className: 'badge-student' },
  'PERSONA-014': { badge: 'Student', className: 'badge-student' },
  'PERSONA-015': { badge: 'Staff', className: 'badge-teacher' },
};

for (const p of personaCollection) {
  personaNames[p.data.artifact] = p.data.title;
}

export function getStaticPaths() {
  let questions: Question[] = [];
  try {
    const raw = readFileSync(resolve('..', 'dist', 'questions.json'), 'utf-8');
    questions = JSON.parse(raw);
  } catch {
    return [];
  }
  return questions.map(q => ({
    params: { slug: q.slug },
    props: { question: q },
  }));
}

const { question } = Astro.props as { question: Question };

// Get related questions (same category, excluding current)
const related = questions
  .filter(q => q.category === question.category && q.slug !== question.slug)
  .slice(0, 3);

const categoryBadgeClass: Record<string, string> = {
  'School Closures': 'badge-community',
  'Staffing Cuts': 'badge-teacher',
  'Tax Impact': 'badge-general',
  'Programs & Classes': 'badge-student',
  'How Decisions Get Made': 'badge-media',
  'Equity & Fairness': 'badge-parent',
  'What Happens Next': 'badge-general',
};

const troveLabelMap: Record<string, string> = {
  'fy27-budget-documents': 'FY27 Budget Documents',
  'school-board-budget-meetings': 'School Board Meetings',
  'city-council-meetings-2026': 'City Council Meetings',
};
---

<BaseLayout title={question.question} activePage="questions" description={question.context}>
  <main class="container">
    <a href={`${base}questions/`} class="back-link">&larr; Back to Questions</a>

    <article class="answer-article">
      <header>
        <span class={`badge ${categoryBadgeClass[question.category] || 'badge-general'}`}>{question.category}</span>
        <h1>{question.question}</h1>
      </header>

      <section class="answer-section">
        <h2>What We Know</h2>
        <p>{question.context}</p>
      </section>

      <section class="evidence-section">
        <h2>Sources</h2>
        <ul class="evidence-list">
          {question.evidence.map(e => (
            <li class="evidence-item">
              <span class="evidence-trove">{troveLabelMap[e.trove] || e.trove}</span>
              <strong>{e.title}</strong>
              <p>{e.detail}</p>
            </li>
          ))}
        </ul>
        <p class="verify-note">
          All sources are public documents and meeting records.
          <a href={`${base}evidence/`}>View all sources &rarr;</a>
        </p>
      </section>

      <section class="personas-section">
        <h2>Who's Asking</h2>
        <div class="persona-tags">
          {question.personas.map(pid => {
            const name = personaNames[pid] || pid;
            const cat = personaCategoryMap[pid];
            const num = pid.replace('PERSONA-', '');
            return (
              <a href={`${base}personas/${pid.toLowerCase()}/`} class="persona-tag">
                <span class={`badge ${cat?.className || 'badge-general'}`}>{cat?.badge || 'Other'}</span>
                {name}
              </a>
            );
          })}
        </div>
      </section>

      {related.length > 0 && (
        <section class="related-section">
          <h2>Related Questions</h2>
          <div class="related-list">
            {related.map(q => (
              <a href={`${base}questions/${q.slug}/`} class="question-card">
                <span class="question-text">{q.question}</span>
                <span class="question-meta">
                  {q.evidence.length} source{q.evidence.length !== 1 ? 's' : ''}
                </span>
              </a>
            ))}
          </div>
        </section>
      )}
    </article>
  </main>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-sky);
    text-decoration: none;
    font-size: 0.9rem;
    transition: transform 0.15s;
  }

  .back-link:hover {
    transform: translateX(-3px);
  }

  .answer-article header {
    margin-bottom: 2rem;
  }

  .answer-article header .badge {
    margin-bottom: 0.75rem;
    display: inline-block;
  }

  .answer-article h1 {
    font-size: 1.75rem;
    line-height: 1.3;
  }

  .answer-article h2 {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
    margin-bottom: 0.75rem;
  }

  .answer-section {
    margin-bottom: 2rem;
  }

  .answer-section p {
    font-size: 1.1rem;
    line-height: 1.75;
  }

  .evidence-section {
    margin-bottom: 2rem;
  }

  .evidence-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .evidence-item {
    padding: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin-bottom: 0.5rem;
  }

  .evidence-trove {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
    display: block;
    margin-bottom: 0.25rem;
  }

  .evidence-item strong {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--color-navy);
  }

  [data-theme="dark"] .evidence-item strong {
    color: var(--color-heading);
  }

  .evidence-item p {
    font-size: 0.9rem;
    color: var(--color-slate);
    margin: 0;
  }

  .verify-note {
    font-size: 0.85rem;
    color: var(--color-slate);
    margin-top: 1rem;
  }

  .personas-section {
    margin-bottom: 2rem;
  }

  .persona-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .persona-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.85rem;
    transition: border-color 0.2s;
  }

  .persona-tag:hover {
    border-color: var(--color-sky);
  }

  .persona-tag .badge {
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
  }

  .related-section {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
  }

  .related-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .question-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .question-card:hover {
    border-color: var(--color-sky);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .question-text {
    font-weight: 500;
    color: var(--color-navy);
  }

  [data-theme="dark"] .question-text {
    color: var(--color-heading);
  }

  .question-meta {
    font-size: 0.8rem;
    color: var(--color-slate);
  }
</style>
