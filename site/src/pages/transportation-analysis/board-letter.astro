---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const base = import.meta.env.BASE_URL;
const entry = await getEntry('transportAnalysis', 'board-letter');

if (!entry) {
  throw new Error('Board letter content is missing.');
}

const { Content } = await render(entry);
---

<BaseLayout
  title="School Board Letter"
  activePage="transportation-analysis"
  description="Problem-solving memo for South Portland school board transportation implementation decisions."
>
  <main class="container">
    <a href={`${base}transportation-analysis/`} class="back-link">&larr; Transportation Analysis</a>
    <p class="section-kicker">Supporting Resource</p>
    <h1>{entry.data.title}</h1>
    <p class="page-lede">
      This memo is for the board and district leadership. It focuses on the implementation choices, disclosures, and
      timelines that still need public clarity after the vote.
    </p>
    <article class="briefing-content">
      <Content />
    </article>
  </main>
</BaseLayout>
