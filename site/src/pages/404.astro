---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Page Not Found" activePage="">
  <main class="container" style="padding: 4rem 1rem; text-align: center;">
    <h1>Page Not Found</h1>
    <p>The page you're looking for doesn't exist or may have moved.</p>
    <p><a href={base}>Return to the homepage</a></p>
  </main>
</BaseLayout>

<script is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
  // Redirect if the URL differs only in casing from the correct base path.
  // GitHub Pages URLs are case-sensitive; this catches common mis-capitalizations.
  (function () {
    var path = window.location.pathname;
    if (path.toLowerCase() === base.toLowerCase() ||
        path.toLowerCase().startsWith(base.toLowerCase())) {
      var corrected = base + path.slice(base.length);
      // Only redirect when casing actually differs (avoid infinite loop)
      if (corrected !== path) {
        window.location.replace(
          window.location.origin + corrected + window.location.search + window.location.hash
        );
      }
    }
  })();
</script>
