---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getTransportCommunityLensEntries } from '../../../lib/transport-content.js';

const base = import.meta.env.BASE_URL;
const transportBriefings = await getCollection('transportBriefings');
const communityLenses = getTransportCommunityLensEntries(transportBriefings);
---

<BaseLayout
  title="Transportation Briefings"
  activePage="transportation-analysis"
  description="Community lens transportation briefings for South Portland's elementary reconfiguration."
>
  <main class="container">
    <a href={`${base}transportation-analysis/`} class="back-link">&larr; Transportation Analysis</a>
    <p class="section-kicker">Briefings</p>
    <h1>Transportation Briefings</h1>
    <p>
      These briefs explain the same transportation questions in plain language for different community audiences.
    </p>

    <section>
      <h2>Community Lenses</h2>
      <div class="card-grid">
        {communityLenses.map(({ entry, lens }) => (
          <a href={`${base}transportation-analysis/briefings/${entry.id}/`} class="card">
            <span class="badge badge-general">Community lens</span>
            <h3>{lens.label}</h3>
            <p>{lens.summary}</p>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
