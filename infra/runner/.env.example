# GitHub repository (owner/repo format)
GITHUB_REPOSITORY=cristoslc/south-portland-school-budget-FY27

# Runner registration token
# Generate at: Settings > Actions > Runners > New self-hosted runner
# Tokens expire after 1 hour — complete setup promptly
RUNNER_TOKEN=

# Runner name (optional, defaults to container hostname)
# RUNNER_NAME=sp-budget-runner

# Runner labels (optional, defaults to self-hosted,linux,x64)
# RUNNER_LABELS=self-hosted,linux,x64
